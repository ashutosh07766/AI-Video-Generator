# ── ReelKaro environment ──────────────────────────────────────────────
# Everything is OPTIONAL for local dev. With no keys set, the app uses
# built-in deterministic fallbacks (rule-based script, silent voiceover),
# so the full create -> preview flow works at ₹0 with zero setup.

# ── LLM (script / caption generation) ────────────────────────────────
# Pick ONE. If none set, a deterministic template-based writer is used.
# Groq free tier (recommended to start): https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Google Gemini free tier: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Text-to-Speech (voiceover) ───────────────────────────────────────
# OPTIONAL. With no key, a free no-key Google Translate TTS is used
# (Indian languages supported) — voiceover works out of the box. Add a
# key below only for higher quality; it takes priority automatically.
# Sarvam (best Indian-language prosody): https://www.sarvam.ai  (₹1,000 free credits)
SARVAM_API_KEY=
# Google Cloud TTS (1M free Neural chars/month)
GOOGLE_TTS_API_KEY=

# ── Storage (final videos) — Cloudflare R2 (10GB free, zero egress) ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=reelkaro-media
R2_PUBLIC_BASE_URL=

# ── Talking avatars (V2) ─────────────────────────────────────────────
# Default = free 2D characters. For premium photoreal avatars:
AVATAR_MODE=
HEYGEN_API_KEY=

# ── Auth: phone OTP ──────────────────────────────────────────────────
# OTP is always REAL (server-issued, single-use, 5-min expiry). With a key
# it's delivered by SMS; without one (dev), the code is shown on screen.
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_TEMPLATE_ID=

# ── Payments: Razorpay (optional) ────────────────────────────────────
# Publishable Key ID → client-side checkout (test mode works with just this):
NEXT_PUBLIC_RAZORPAY_KEY_ID=
# Add the secret too for verified SERVER-side orders (recommended for prod):
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Without any of these, upgrade uses a mock checkout (no real charge).

# ── Database — Neon Postgres (see SETUP.md) ──────────────────────────
DATABASE_URL=

# ── Redis — Upstash (OTP, rate-limit; REST for web, rediss for worker) ─
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=

# ── Sessions ─────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
SESSION_SECRET=

# ── Payments webhook (Razorpay dashboard → Webhooks) ─────────────────
RAZORPAY_WEBHOOK_SECRET=

# ── Worker ───────────────────────────────────────────────────────────
WORKER_CONCURRENCY=2

# ── App ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=ReelKaro
